# Local demo login without Supabase (admin@berc.local / Admin@123)
DEMO_MODE="true"

# Supabase (Project Settings → API) — set DEMO_MODE=false when using these
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

JWT_SECRET="change-me-to-a-long-random-secret-in-production"
APP_URL="http://localhost:3000"

# Optional SMTP for email notifications
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="BERC OMS <noreply@berc.local>"

# Seed admin
SEED_ADMIN_EMAIL="admin@berc.local"
SEED_ADMIN_PASSWORD="Admin@123"

# Google OAuth (Drive + Meet) — optional
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (Teams + Outlook) — optional
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
